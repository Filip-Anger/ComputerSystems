SigmaA, IP <- IP(Bbus), IP(Abus) + 1
{SigmaA = ip, IP = ip + 1}

SigmaR <- RAM[SigmaA]
{SigmaA = ip, IP = ip + 1, SigmaR = RAM[ip]}

IR <- SigmaR(Bbus)
{SigmaA = ip, IP = ip + 1, SigmaR = RAM[ip], IR = RAM[ip]}


RA, CC <- RA(Abus) + RB(Bbus), ALU.cc
{SigmaA = ip, IP = ip + 1, SigmaR = RAM[ip], IR = RAM[ip], RA = ra + rb, CC = ALU.cc}